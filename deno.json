{
	"version": "0.2.0",
	"tasks": {
		"dev": "deno run --allow-net --allow-read --allow-write --unstable-kv --allow-env --watch src/main.ts --dev",
		"start": "deno run --allow-net --allow-read --allow-write --unstable-kv --allow-env src/main.ts",
		"write-schema": "deno run --allow-read --allow-write src/config.ts && deno fmt config.schema.json"
	},
	"fmt": {
		"singleQuote": true,
		"semiColons": true,
		"useTabs": true,
		"indentWidth": 4,
		"lineWidth": 100
	},
	"imports": {
		"@mikaelporttila/rss": "jsr:@mikaelporttila/rss@1.1.2",
		"@std/async": "jsr:@std/async@^1.3.0",
		"@std/fs": "jsr:@std/fs@^1.0.23",
		"@std/html": "jsr:@std/html@^1.0.6",
		"@std/path": "jsr:@std/path@^1.1.4",
		"@valibot/to-json-schema": "jsr:@valibot/to-json-schema@^1.6.0",
		"cheerio": "npm:cheerio@^1.2.0",
		"valibot": "jsr:@valibot/valibot@^1.3.1",
		"xml2js": "npm:xml2js@^0.6.2"
	}
}
